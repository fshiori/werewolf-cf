{
  "name": "werewolf-cf",
  "version": "1.0.0",
  "description": "人狼遊戲 Cloudflare Workers 重構版",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create werewolf-db",
    "d1:migrate": "wrangler d1 migrations apply werewolf-db --local",
    "d1:migrate:prod": "wrangler d1 migrations apply werewolf-db",
    "test": "vitest",
    "typecheck": "wrangler types"
  },
  "keywords": [
    "werewolf",
    "cloudflare",
    "workers",
    "game"
  ],
  "author": "EricChen",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@cloudflare/workers-types": "^4.20240512.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4",
    "wrangler": "^3.57.1"
  },
  "dependencies": {
    "hono": "^4.3.11"
  }
}
