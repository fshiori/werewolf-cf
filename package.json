{
  "name": "werewolf-cf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "check:wrangler": "node scripts/check-wrangler-config.mjs",
    "check:d1-schema": "node scripts/check-d1-schema.mjs",
    "check:deploy": "npm test && npm run typecheck && npm run check:wrangler -- --production",
    "smoke:production": "node scripts/smoke-production-readonly.mjs",
    "predeploy": "npm run check:deploy",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260423.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.14.4"
  }
}
